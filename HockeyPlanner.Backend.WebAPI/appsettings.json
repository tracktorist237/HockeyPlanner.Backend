{
  "Jwt": {
    "Issuer": "HockeyPlanner",
    "Audience": "HockeyPlanner.Frontend",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 60,
    "EmailTokenHours": 24,
    "PasswordResetTokenMinutes": 30
  },
  "Email": {
    "SmtpPort": 587,
    "EnableSsl": true,
    "FromName": "Hockey Planner",
    "FrontendBaseUrl": "http://localhost:3000"
  },
  "Vapid": {
    "Subject": "mailto:admin@hockey-planner.local"
  },
  "Storage": {
    "Provider": "ImageKit"
  },
  "S3": {
    "Endpoint": "https://s3.twcstorage.ru",
    "Region": "ru-1",
    "Bucket": "",
    "AccessKey": "",
    "SecretKey": "",
    "PublicBaseUrl": "",
    "ForcePathStyle": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
